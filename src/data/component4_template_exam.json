                        {
                            "id": "a",
                            "type": "multi_select",
                            "marks": 2,
                            "question": "A producer wants to remove the sound of the hi-hat bleeding into the snare drum microphone. Which processor and setting should they use?",
                            "options": [
                                "Noise Gate",
                                "Chorus Pedal",
                                "Set Threshold below snare hits but above hi-hat bleed",
                                "Fast attack, long release"
                            ],
                            "answer": [
                                "Noise Gate",
                                "Set Threshold below snare hits but above hi-hat bleed"
                            ],
                            "rationale": "A noise gate silences the channel when the signal drops below a threshold, removing background bleed between snare hits."
                        },
                        {
                            "id": "b",
                            "type": "multiple_choice",
                            "marks": 2,
                            "question": "Which dynamic processor is used to catch only the loudest, sharpest peaks of a snare transient without affecting the body of the sound?",
                            "options": [
                                "Limiter",
                                "Expander",
                                "Compressor with slow attack",
                                "Compressor with very fast attack and high ratio"
                            ],
                            "answer": "Compressor with very fast attack and high ratio",
                            "rationale": "A fast attack catches the initial transient spike, and a high ratio turns it down aggressively (acting almost like a limiter)."
                        }
                    ]
                },
