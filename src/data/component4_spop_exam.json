                        }
                    ]
                },
                {
                    "id": "q3",
                    "title": "Question 3: Analog Recording",
                    "totalMarks": 1,
                    "parts": [
                        {
                            "id": "a",
                            "type": "multiple_choice",
                            "marks": 1,
                            "question": "When recording to analog magnetic tape (common in classic rock), driving the input signal 'into the red' produces what desirable effect?",
                            "options": [
                                "Digital clipping and glitching",
                                "Harmonic distortion (Tape Saturation)",
                                "Phase cancellation",
                                "An automatic noise gate"
                            ],
                            "answer": "Harmonic distortion (Tape Saturation)",
                            "rationale": "Unlike digital clipping (which sounds harsh), analog tape responds to hot signals by gently compressing and adding warm harmonic saturation."
                        }
                    ]
                },
                {
                    "id": "q4",
                    "title": "Question 4: Hardware Processing",
                    "totalMarks": 6,
                    "parts": [
                        {
                            "id": "a",
                            "type": "multi_select",
                            "marks": 2,
                            "question": "A producer wants to remove the sound of the hi-hat bleeding into the snare drum microphone. Which processor and setting should they use?",
                            "options": [
                                "Noise Gate",
                                "Chorus Pedal",
                                "Set Threshold below snare hits but above hi-hat bleed",
                                "Fast attack, long release"
                            ],
                            "answer": [
                                "Noise Gate",
                                "Set Threshold below snare hits but above hi-hat bleed"
                            ],
                            "rationale": "A noise gate silences the channel when the signal drops below a threshold, removing background bleed between snare hits."
                        },
                        {
                            "id": "b",
                            "type": "multiple_choice",
                            "marks": 2,
                            "question": "Which dynamic processor is used to catch only the loudest, sharpest peaks of a snare transient without affecting the body of the sound?",
                            "options": [
                                "Limiter",
                                "Expander",
                                "Compressor with slow attack",
                                "Compressor with very fast attack and high ratio"
                            ],
                            "answer": "Compressor with very fast attack and high ratio",
                            "rationale": "A fast attack catches the initial transient spike, and a high ratio turns it down aggressively (acting almost like a limiter)."
                        },
                        {
                            "id": "c",
                            "type": "multiple_choice",
                            "marks": 1,
                            "question": "Which dynamic processor is most commonly used to automatically reduce the level of a bass track whenever the kick drum hits?",
                            "options": [
                                "Sidechain Compressor",
                                "De-esser",
                                "Multiband Compressor",
                                "Limiter"
                            ],
                            "answer": "Sidechain Compressor",
                            "rationale": "By feeding the kick drum signal into the compressor's key input, the compressor turns down (ducks) the bass only when the kick hits, making room in the mix."
                        },
                        {
                            "id": "d",
                            "type": "multiple_choice",
                            "marks": 1,
                            "question": "What is a De-esser primarily designed to do during vocal processing?",
                            "options": [
                                "Reduce harsh 'S' and 'T' consonant sounds",
                                "Add analog-style saturation to the vocal",
                                "Widen the stereo image of the lead vocal",
                                "Remove background noise between vocal phrases"
                            ],
                            "answer": "Reduce harsh 'S' and 'T' consonant sounds",
                            "rationale": "A De-esser is a specific frequency-dependent compressor that quickly tames harsh high-frequency sibilance."
                        }
                    ]
                },
                {
                    "id": "q5",
                    "title": "Question 5: Compressor Parameters",
                    "totalMarks": 2,
                    "parts": [
                        {
                            "id": "a",
                            "type": "multiple_choice",
                            "marks": 1,
                            "question": "Which compressor parameter determines how much the volume is reduced once the signal crosses the threshold?",
                            "options": [
                                "Attack",
                                "Release",
                                "Ratio",
                                "Makeup Gain"
                            ],
                            "answer": "Ratio",
                            "rationale": "Ratio (e.g. 4:1) dictates that for every 4dB over the threshold, only 1dB is allowed out."
                        },
                        {
                            "id": "b",
                            "type": "multiple_choice",
                            "marks": 1,
                            "question": "If you want the initial 'crack' or transient of a kick drum to pass through the compressor unaffected before the volume is reduced, how should you set the attack time?",
                            "options": [
                                "Extremely Fast (0.1ms)",
                                "Medium-Slow (~10-30ms)",
                                "Attack time does not affect transients",
                                "Zero"
                            ],
                            "answer": "Medium-Slow (~10-30ms)",
                            "rationale": "A slower attack time lets the punchy transient sneak past the compressor before it clamps down."
                        }
                    ]
                },
                {
                    "id": "q6",
                    "title": "Question 6: Mastering for Streaming",
                    "totalMarks": 3,
                    "parts": [
                        {
                            "id": "a",
                            "type": "multiple_choice",
                            "marks": 1,
                            "question": "What is the industry standard (Spotify/Apple Music) Integrated Loudness target for mastering a track?",
                            "options": [
                                "-6 LUFS",
                                "-14 LUFS",
                                "0 LUFS",
                                "-23 dBFS"
                            ],
                            "answer": "-14 LUFS",
                            "rationale": "Streaming platforms normalize audio. Aiming for -14 LUFS is the current standard to prevent the platform from turning your track down and crushing its dynamics."
                        },
                        {
                            "id": "b",
                            "type": "multiple_choice",
                            "marks": 1,
                            "question": "To prevent inter-sample clipping when a digital file is converted to analog (or MP3), what should True Peak limiters be set to?",
                            "options": [
                                "0 dBTP",
                                "+1 dBTP",
                                "-1 dBTP",
                                "-14 dBTP"
                            ],
                            "answer": "-1 dBTP",
                            "rationale": "Leaving 1 decibel of headroom (-1 dB True Peak) ensures the conversion process doesn't cause clipping distortion."
                        }
                    ]
                }
            ]
